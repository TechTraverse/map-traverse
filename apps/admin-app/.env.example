DB_HOST=localhost
DB_PORT=5432
DB_NAME=gis
DB_USER=postgres
DB_PASSWORD=postgres
PORT=3001

# Auth (leave unset to disable auth in dev mode)
# Generate hash with: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=change-me-in-production

# Comma-separated list of deployment environments
ADMIN_ENVIRONMENTS=development,staging,production

# Allowed CORS origins (comma-separated). Leave unset to allow all origins (dev mode).
# CORS_ORIGINS=https://app.example.com,https://staging.example.com
