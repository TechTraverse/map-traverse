{
  "name": "storybook-components",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for OGC API-based map component library and demo app",
  "scripts": {
    "build": "pnpm -r build",
    "dev:lib": "pnpm --filter @ogc-maps/storybook-components dev",
    "dev:app": "pnpm --filter map-client dev",
    "storybook": "pnpm --filter @ogc-maps/storybook-components storybook",
    "build:lib": "pnpm --filter @ogc-maps/storybook-components build",
    "build:app": "pnpm --filter map-client build",
    "release": "pnpm build && changeset publish",
    "changeset": "changeset",
    "test": "pnpm --filter @ogc-maps/storybook-components test",
    "test:coverage": "pnpm --filter @ogc-maps/storybook-components test:coverage",
    "verify": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "read-yaml-file>js-yaml": "3.14.1",
      "path-to-regexp@~0.1.12": "0.1.13",
      "jszip": "^3.10.1",
      "lodash": "^4.18.0",
      "tmp": "^0.2.6"
    },
    "patchedDependencies": {
      "@mapbox/shp-write": "patches/@mapbox__shp-write.patch"
    }
  }
}